<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>...</title>

<style>
body {
    margin: 0;
    background: black;
    color: #9aff9a;
    font-family: monospace;
    overflow: hidden;
    cursor: none;
}

#noise {
    position: fixed;
    width: 100%;
    height: 100%;
    background: repeating-radial-gradient(circle, #000 0px, #000 2px, #010 3px);
    opacity: 0.08;
    animation: noiseMove 0.2s infinite;
}

@keyframes noiseMove {
    0% {transform: translate(0,0);}
    50% {transform: translate(-2px,2px);}
    100% {transform: translate(2px,-2px);}
}

.center {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%,-50%);
    font-size: 32px;
    text-align: center;
    letter-spacing: 3px;
}

#mainText {
    transition: opacity 0.3s;
}

#fakeCursor {
    position: fixed;
    width: 10px;
    height: 10px;
    background: #9aff9a;
    border-radius: 50%;
    pointer-events: none;
    box-shadow: 0 0 10px #9aff9a;
}

#ghostText {
    position: absolute;
    width: 100%;
    text-align: center;
    top: 70%;
    font-size: 14px;
    opacity: 0;
    color: #55ff55;
}

.flash {
    position: fixed;
    width: 100%;
    height: 100%;
    background: white;
    opacity: 0;
    pointer-events: none;
}
</style>
</head>

<body>

<div id="noise"></div>
<div class="flash" id="flash"></div>
<div id="fakeCursor"></div>

<div class="center">
    <div id="mainText">stay</div>
</div>

<div id="ghostText">it saw that</div>

<script>
let messages = [
    "stay",
    "don't move",
    "it tracks motion",
    "too late",
    "why did you move",
    "stay still",
    "it gets closer when you move"
];

let text = document.getElementById("mainText");
let ghost = document.getElementById("ghostText");
let flash = document.getElementById("flash");

let i = 0;
setInterval(() => {
    text.style.opacity = 0;

    setTimeout(() => {
        text.innerText = messages[i];
        text.style.opacity = 1;
        i = (i + 1) % messages.length;
    }, 300);
}, 3500);


// FAKE CURSOR LAG (this feels WRONG to people)
let fake = document.getElementById("fakeCursor");
let mouseX = 0, mouseY = 0;
let fakeX = 0, fakeY = 0;

document.addEventListener("mousemove", e => {
    mouseX = e.clientX;
    mouseY = e.clientY;

    if (Math.random() > 0.7) {
        ghost.style.opacity = 1;
        setTimeout(()=> ghost.style.opacity = 0, 1000);
    }
});

function animateCursor() {
    fakeX += (mouseX - fakeX) * 0.08;
    fakeY += (mouseY - fakeY) * 0.08;

    fake.style.left = fakeX + "px";
    fake.style.top = fakeY + "px";

    requestAnimationFrame(animateCursor);
}
animateCursor();


// RANDOM FREEZE
setInterval(() => {
    if (Math.random() > 0.75) {
        document.body.style.pointerEvents = "none";
        text.innerText = "don't move";

        setTimeout(() => {
            document.body.style.pointerEvents = "auto";
        }, 1500 + Math.random()*2000);
    }
}, 4000);


// SCREEN FLASH (very rare)
setInterval(() => {
    if (Math.random() > 0.92) {
        flash.style.opacity = 0.9;
        text.innerText = "it found you";

        setTimeout(() => {
            flash.style.opacity = 0;
        }, 80);
    }
}, 3000);


// TIME DISTORTION (tab title changes)
setInterval(() => {
    let titles = [
        "…",
        "still here?",
        "it knows",
        "leave",
        "too late"
    ];
    document.title = titles[Math.floor(Math.random()*titles.length)];
}, 2000);


// AFTER A WHILE, IT GETS WORSE
setTimeout(() => {
    setInterval(() => {
        if (Math.random() > 0.6) {
            document.body.style.transform =
                "translate("+(Math.random()*20-10)+"px,"+(Math.random()*20-10)+"px)";
            setTimeout(()=>{
                document.body.style.transform="translate(0,0)";
            }, 100);
        }
    }, 1500);
}, 15000);

</script>

</body>
</html>
